@startuml
title "Контейнерная диаграмма"
top to bottom direction

hide stereotype
skinparam ranksep 60
skinparam nodesep 30
skinparam {
  arrowFontSize 10
  defaultTextAlignment center
  wrapWidth 200
  maxMessageSize 100
  shadowing false
}

skinparam rectangle<<UsersWeb>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<UsersAndroid>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<UsersIos>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<System>>{
  BackgroundColor #2b85e7
  FontColor #f1ffff
  BorderColor #1e73ce
}
rectangle "Пользователи" <<Users>> as Users {
  skinparam RectangleBorderColor<<Users>> #2b85e7
  skinparam RectangleFontColor<<Users>> #2b85e7
  skinparam RectangleBorderStyle<<Users>> dashed

  rectangle "Web (браузер)\n<size:10>[HTTP/1.1, HTTP/2]</size>\n\nПодключение по браузеру" <<UsersWeb>> as UsersWeb
  rectangle "Android\n<size:10>[HTTP/1.1, HTTP/2, WebSocket]</size>\n\nМобильное приложение" <<UsersAndroid>> as UsersAndroid
  rectangle "iOS\n<size:10>[HTTP/1.1, HTTP/2, WebSocket]</size>\n\nМобильное приложение" <<UsersIos>> as UsersIos
}
rectangle "Система\n\nСистема обработки пользовательских запросов" <<System>> as System

UsersWeb .[#15803d,thickness=2].> System : <color:#15803d>Загрузка веб-интерфейса и API-запросы\n<size:8>[<color:#15803d>HTTPS]</size>
UsersAndroid .[#15803d,thickness=2].> System : <color:#15803d>API-запросы и уведомления в реальном \n<color:#15803d>времени\n<size:8>[<color:#15803d>HTTPS]</size>
UsersIos .[#15803d,thickness=2].> System : <color:#15803d>API-запросы и уведомления в реальном \n<color:#15803d>времени\n<size:8>[<color:#15803d>HTTPS]</size>
@enduml
