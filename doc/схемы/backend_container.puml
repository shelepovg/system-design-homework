@startuml
title "Контейнерная диаграмма"
top to bottom direction

hide stereotype
skinparam ranksep 60
skinparam nodesep 30
skinparam {
  arrowFontSize 10
  defaultTextAlignment center
  wrapWidth 200
  maxMessageSize 100
  shadowing false
}

skinparam rectangle<<SystemApiGateway>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemMonitoring>>{
  BackgroundColor #2b85e7
  FontColor #f1ffff
  BorderColor #1e73ce
}
skinparam rectangle<<SystemBackendUserService>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemBackendRequestProcessingService>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemBackendPaymentService>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemBackendNotificationService>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemBackendAuditService>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemIam>>{
  BackgroundColor #2b85e7
  FontColor #f1ffff
  BorderColor #1e73ce
}
skinparam rectangle<<System_ext>>{
  BackgroundColor #827a8e
  FontColor #ffffff
  BorderColor #6c6477
}
skinparam rectangle<<SystemStorage>>{
  BackgroundColor #2b85e7
  FontColor #f1ffff
  BorderColor #1e73ce
}
skinparam queue<<SystemEventBus>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
rectangle "Система" <<System>> as System {
  skinparam RectangleBorderColor<<System>> #2b85e7
  skinparam RectangleFontColor<<System>> #2b85e7
  skinparam RectangleBorderStyle<<System>> dashed

  rectangle "api-gateway\n<size:10>[[Spring Cloud Gateway]]</size>\n\nМаршрутизация API, аутентификация, авторизация, rate limiting" <<SystemApiGateway>> as SystemApiGateway
  rectangle "Система мониторинга\n\nСбор логов и метрик, обработка, хранение, дашборды и алертинг" <<SystemMonitoring>> as SystemMonitoring
  rectangle "Обработка пользовательских запросов" <<SystemBackend>> as SystemBackend {
    skinparam RectangleBorderColor<<SystemBackend>> #2b85e7
    skinparam RectangleFontColor<<SystemBackend>> #2b85e7
    skinparam RectangleBorderStyle<<SystemBackend>> dashed

    rectangle "User Service\n<size:10>[[Spring Boot]]</size>\n\nПрофили, сессии, роли" <<SystemBackendUserService>> as SystemBackendUserService
    rectangle "Request Processing Service\n<size:10>[[Spring Boot]]</size>\n\nОбработка запросов (PROCESS_DATA, REPORT, EXPORT, RESOURCES)" <<SystemBackendRequestProcessingService>> as SystemBackendRequestProcessingService
    rectangle "Payment Service\n<size:10>[[Spring Boot]]</size>\n\nПлатежи, интеграция с провайдером, Outbox" <<SystemBackendPaymentService>> as SystemBackendPaymentService
    rectangle "Notification Service\n<size:10>[[Spring Boot]]</size>\n\nУведомления (Email, SMS, Push), потребитель событий" <<SystemBackendNotificationService>> as SystemBackendNotificationService
    rectangle "Audit Service\n<size:10>[[Spring Boot]]</size>\n\nАудит операций и безопасности" <<SystemBackendAuditService>> as SystemBackendAuditService
  }
  rectangle "iam\n<size:10>[[Keycloak]]</size>\n\nIdentity and Access Management" <<SystemIam>> as SystemIam
  rectangle "Хранение данных\n\nБД и кэш" <<SystemStorage>> as SystemStorage
  queue "Event Bus\n<size:10>[[Apache Kafka]]</size>\n\nАсинхронные события между сервисами" <<SystemEventBus>> as SystemEventBus
}
rectangle "Внешние системы\n\nВнешние системы" <<System_ext>> as System_ext

SystemBackendUserService .[#15803d,thickness=2].> SystemIam : <color:#15803d>Синхронизация пользователей, ролей и \n<color:#15803d>сессий с Keycloak\n<size:8>[<color:#15803d>HTTPS]</size>
SystemBackendUserService .[#6366f1,thickness=2].> SystemStorage : <color:#6366f1>[...]\n<size:8>[<color:#6366f1>TCP]</size>
SystemBackendRequestProcessingService .[#6366f1,thickness=2].> SystemStorage : <color:#6366f1>[...]\n<size:8>[<color:#6366f1>TCP]</size>
SystemBackendRequestProcessingService .[#6366f1,thickness=2].> SystemEventBus : <color:#6366f1>Публикация событий (уведомления, аудит)\n<size:8>[<color:#6366f1>TCP]</size>
SystemBackendPaymentService .[#15803d,thickness=2].> System_ext : <color:#15803d>Инициация платежа; приём Webhook\n<size:8>[<color:#15803d>HTTPS]</size>
SystemBackendPaymentService .[#6366f1,thickness=2].> SystemStorage : <color:#6366f1>Транзакции, outbox\n<size:8>[<color:#6366f1>TCP]</size>
SystemBackendPaymentService .[#6366f1,thickness=2].> SystemEventBus : <color:#6366f1>События платежей (уведомления, аудит)\n<size:8>[<color:#6366f1>TCP]</size>
SystemBackendNotificationService .[#15803d,thickness=2].> System_ext : <color:#15803d>Отправка (Email, SMS, Push)\n<size:8>[<color:#15803d>HTTPS]</size>
SystemBackendNotificationService .[#6366f1,thickness=2].> SystemStorage : <color:#6366f1>Статусы доставки\n<size:8>[<color:#6366f1>TCP]</size>
SystemBackendNotificationService .[#6366f1,thickness=2].> SystemEventBus : <color:#6366f1>Потребление событий уведомлений\n<size:8>[<color:#6366f1>TCP]</size>
SystemBackendAuditService .[#6366f1,thickness=2].> SystemStorage : <color:#6366f1>Запись аудит-логов\n<size:8>[<color:#6366f1>TCP]</size>
SystemBackendAuditService .[#6366f1,thickness=2].> SystemEventBus : <color:#6366f1>Потребление событий аудита\n<size:8>[<color:#6366f1>TCP]</size>
SystemApiGateway .[#6366f1,thickness=2].> SystemBackendUserService : <color:#6366f1>Маршрутизация /api/users, профиль, \n<color:#6366f1>сессии\n<size:8>[<color:#6366f1>HTTP]</size>
SystemApiGateway .[#6366f1,thickness=2].> SystemBackendRequestProcessingService : <color:#6366f1>Маршрутизация /api/requests\n<size:8>[<color:#6366f1>HTTP]</size>
SystemApiGateway .[#6366f1,thickness=2].> SystemBackendPaymentService : <color:#6366f1>Маршрутизация /api/payments\n<size:8>[<color:#6366f1>HTTP]</size>
SystemApiGateway .[#6366f1,thickness=2].> SystemBackendNotificationService : <color:#6366f1>Маршрутизация /api/notifications, \n<color:#6366f1>настройки\n<size:8>[<color:#6366f1>HTTP]</size>
SystemMonitoring .[#6366f1,thickness=2].> SystemBackendUserService : <color:#6366f1>[...]
SystemMonitoring .[#6366f1,thickness=2].> SystemBackendRequestProcessingService : <color:#6366f1>[...]
SystemMonitoring .[#6366f1,thickness=2].> SystemBackendPaymentService : <color:#6366f1>[...]
SystemMonitoring .[#6366f1,thickness=2].> SystemBackendNotificationService : <color:#6366f1>[...]
SystemMonitoring .[#6366f1,thickness=2].> SystemBackendAuditService : <color:#6366f1>[...]
@enduml
