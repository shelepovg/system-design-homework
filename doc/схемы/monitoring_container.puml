@startuml
title "Контейрная диаграмма"
top to bottom direction

hide stereotype
skinparam ranksep 60
skinparam nodesep 30
skinparam {
  arrowFontSize 10
  defaultTextAlignment center
  wrapWidth 200
  maxMessageSize 100
  shadowing false
}

skinparam rectangle<<SystemMonitoringLogCollector>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemMonitoringMetricsCollector>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam queue<<SystemMonitoringLogBus>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemMonitoringMetricsStorage>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemLoadBalancer>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemMonitoringLogProcessor>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemMonitoringAlerting>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemFront>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemMonitoringLogStorage>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemApiGateway>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemMonitoringLogUi>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
skinparam rectangle<<SystemBackend>>{
  BackgroundColor #2b85e7
  FontColor #f1ffff
  BorderColor #1e73ce
}
skinparam rectangle<<SystemIam>>{
  BackgroundColor #2b85e7
  FontColor #f1ffff
  BorderColor #1e73ce
}
skinparam rectangle<<SystemStorage>>{
  BackgroundColor #2b85e7
  FontColor #f1ffff
  BorderColor #1e73ce
}
skinparam queue<<SystemEventBus>>{
  BackgroundColor #23a2d9
  FontColor #ffffff
  BorderColor #1892c5
}
rectangle "Система" <<System>> as System {
  skinparam RectangleBorderColor<<System>> #2b85e7
  skinparam RectangleFontColor<<System>> #2b85e7
  skinparam RectangleBorderStyle<<System>> dashed

  rectangle "Система мониторинга" <<SystemMonitoring>> as SystemMonitoring {
    skinparam RectangleBorderColor<<SystemMonitoring>> #2b85e7
    skinparam RectangleFontColor<<SystemMonitoring>> #2b85e7
    skinparam RectangleBorderStyle<<SystemMonitoring>> dashed

    rectangle "Сбор логов\n<size:10>[[Fluent Bit]]</size>\n\nАгенты на узлах: сбор и пересылка логов с сервисов" <<SystemMonitoringLogCollector>> as SystemMonitoringLogCollector
    rectangle "Сбор метрик\n<size:10>[[Prometheus / OpenTelemetry Collector]]</size>\n\nСкрейпинг и приём метрик с сервисов и инфраструктуры" <<SystemMonitoringMetricsCollector>> as SystemMonitoringMetricsCollector
    queue "Шина логов\n<size:10>[[Apache Kafka]]</size>\n\nБуфер и поток логов, сглаживание пиков" <<SystemMonitoringLogBus>> as SystemMonitoringLogBus
    rectangle "Хранилище метрик\n<size:10>[Prometheus TSDB / VictoriaMetrics]</size>\n\nВременные ряды, retention (real-time / 7 дней / 90 дней)" <<SystemMonitoringMetricsStorage>> as SystemMonitoringMetricsStorage
    rectangle "Обработка логов\n<size:10>[[Vector]]</size>\n\nПарсинг, обогащение, маршрутизация, маскирование PII" <<SystemMonitoringLogProcessor>> as SystemMonitoringLogProcessor
    rectangle "Алертинг\n<size:10>[[Grafana Alerting]]</size>\n\nПравила алертов, группировка, уведомления (PagerDuty, Slack, Email)" <<SystemMonitoringAlerting>> as SystemMonitoringAlerting
    rectangle "Хранилище логов\n<size:10>[[Elasticsearch]]</size>\n\nИндексация и хранение (hot/warm/cold)" <<SystemMonitoringLogStorage>> as SystemMonitoringLogStorage
    rectangle "Представление логов, дашборды и анализ\n<size:10>[[Grafana]]</size>\n\nПоиск, фильтрация, просмотр логов для операторов и разработчиков" <<SystemMonitoringLogUi>> as SystemMonitoringLogUi
  }
  rectangle "load-balancer\n<size:10>[[Nginx]]</size>\n\nЕдиная точка входа: распределение трафика, TLS termination" <<SystemLoadBalancer>> as SystemLoadBalancer
  rectangle "front\n<size:10>[[React]]</size>\n\nВеб-интерфейс для взаимодействия с системой" <<SystemFront>> as SystemFront
  rectangle "api-gateway\n<size:10>[[Spring Cloud Gateway]]</size>\n\nМаршрутизация API, аутентификация, авторизация, rate limiting" <<SystemApiGateway>> as SystemApiGateway
  rectangle "Обработка пользовательских запросов\n<size:10>[[Spring Boot]]</size>\n\nМикросервисы: пользователи, запросы, платежи, уведомления, аудит" <<SystemBackend>> as SystemBackend
  rectangle "iam\n<size:10>[[Keycloak]]</size>\n\nIdentity and Access Management" <<SystemIam>> as SystemIam
  rectangle "Хранение данных\n\nБД и кэш" <<SystemStorage>> as SystemStorage
  queue "Event Bus\n<size:10>[[Apache Kafka]]</size>\n\nАсинхронные события между сервисами" <<SystemEventBus>> as SystemEventBus
}

SystemMonitoringLogCollector .[#6366f1,thickness=2].> SystemMonitoringLogBus : <color:#6366f1>Пересылка логов в шину\n<size:8>[<color:#6366f1>TCP]</size>
SystemMonitoringLogBus .[#6366f1,thickness=2].> SystemMonitoringLogProcessor : <color:#6366f1>Чтение из топиков\n<size:8>[<color:#6366f1>TCP]</size>
SystemMonitoringLogProcessor .[#6366f1,thickness=2].> SystemMonitoringLogStorage : <color:#6366f1>Индексация и запись в хранилище\n<size:8>[<color:#6366f1>HTTP]</size>
SystemMonitoringLogStorage .[#6366f1,thickness=2].> SystemMonitoringLogUi : <color:#6366f1>Запросы поиска и выборок\n<size:8>[<color:#6366f1>HTTP]</size>
SystemMonitoringMetricsStorage .[#6366f1,thickness=2].> SystemMonitoringLogUi : <color:#6366f1>Запросы к временным рядам (PromQL)\n<size:8>[<color:#6366f1>HTTP]</size>
SystemMonitoringMetricsCollector .[#6366f1,thickness=2].> SystemMonitoringMetricsStorage : <color:#6366f1>Скрейпинг и запись метрик\n<size:8>[<color:#6366f1>HTTP]</size>
SystemMonitoringMetricsStorage .[#6366f1,thickness=2].> SystemMonitoringAlerting : <color:#6366f1>Вычисление правил алертов\n<size:8>[<color:#6366f1>HTTP]</size>
SystemMonitoringLogCollector .[#6366f1,thickness=2].> SystemLoadBalancer : <color:#6366f1>Сбор access/error логов Nginx\n<size:8>[<color:#6366f1>TCP]</size>
SystemMonitoringLogCollector .[#6366f1,thickness=2].> SystemFront : <color:#6366f1>Сбор логов веб-сервера и SPA\n<size:8>[<color:#6366f1>TCP]</size>
SystemMonitoringLogCollector .[#6366f1,thickness=2].> SystemApiGateway : <color:#6366f1>Сбор логов шлюза (запросы, ошибки)\n<size:8>[<color:#6366f1>TCP]</size>
SystemMonitoringLogCollector .[#6366f1,thickness=2].> SystemIam : <color:#6366f1>Сбор логов Keycloak/IAM\n<size:8>[<color:#6366f1>TCP]</size>
SystemMonitoringLogCollector .[#6366f1,thickness=2].> SystemBackend : <color:#6366f1>Сбор логов приложения\n<size:8>[<color:#6366f1>TCP]</size>
SystemMonitoringLogCollector .[#6366f1,thickness=2].> SystemStorage : <color:#6366f1>[...]\n<size:8>[<color:#6366f1>TCP]</size>
SystemMonitoringLogCollector .[#6366f1,thickness=2].> SystemEventBus : <color:#6366f1>Сбор логов Kafka\n<size:8>[<color:#6366f1>TCP]</size>
SystemMonitoringMetricsCollector .[#6366f1,thickness=2].> SystemLoadBalancer : <color:#6366f1>Скрейпинг метрик Nginx\n<size:8>[<color:#6366f1>HTTP]</size>
SystemMonitoringMetricsCollector .[#6366f1,thickness=2].> SystemFront : <color:#6366f1>Сбор метрик веб-сервера\n<size:8>[<color:#6366f1>HTTP]</size>
SystemMonitoringMetricsCollector .[#6366f1,thickness=2].> SystemApiGateway : <color:#6366f1>Скрейпинг метрик шлюза\n<size:8>[<color:#6366f1>HTTP]</size>
SystemMonitoringMetricsCollector .[#6366f1,thickness=2].> SystemIam : <color:#6366f1>Сбор метрик Keycloak/IAM\n<size:8>[<color:#6366f1>HTTP]</size>
SystemMonitoringMetricsCollector .[#6366f1,thickness=2].> SystemBackend : <color:#6366f1>Скрейпинг метрик\n<size:8>[<color:#6366f1>HTTP]</size>
SystemMonitoringMetricsCollector .[#6366f1,thickness=2].> SystemStorage : <color:#6366f1>[...]\n<size:8>[<color:#6366f1>HTTP]</size>
SystemMonitoringMetricsCollector .[#6366f1,thickness=2].> SystemEventBus : <color:#6366f1>Сбор метрик Kafka\n<size:8>[<color:#6366f1>HTTP]</size>
SystemLoadBalancer .[#6366f1,thickness=2].> SystemFront : <color:#6366f1>Раздача статики и проксирование API\n<size:8>[<color:#6366f1>HTTP]</size>
SystemFront .[#6366f1,thickness=2].> SystemApiGateway : <color:#6366f1>Вызовы API с фронтенда\n<size:8>[<color:#6366f1>HTTP]</size>
SystemApiGateway .[#15803d,thickness=2].> SystemIam : <color:#15803d>Валидация JWT, проверка прав, JWKS\n<size:8>[<color:#15803d>HTTPS]</size>
SystemApiGateway .[#6366f1,thickness=2].> SystemBackend : <color:#6366f1>[...]\n<size:8>[<color:#6366f1>HTTP]</size>
SystemBackend .[#15803d,thickness=2].> SystemIam : <color:#15803d>Синхронизация пользователей, ролей и \n<color:#15803d>сессий с Keycloak\n<size:8>[<color:#15803d>HTTPS]</size>
SystemBackend .[#6366f1,thickness=2].> SystemStorage : <color:#6366f1>[...]\n<size:8>[<color:#6366f1>TCP]</size>
SystemBackend .[#6366f1,thickness=2].> SystemEventBus : <color:#6366f1>[...]\n<size:8>[<color:#6366f1>TCP]</size>
@enduml
