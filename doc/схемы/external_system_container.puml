@startuml
title "Контейнерная диаграмма"
top to bottom direction

hide stereotype
skinparam ranksep 60
skinparam nodesep 30
skinparam {
  arrowFontSize 10
  defaultTextAlignment center
  wrapWidth 200
  maxMessageSize 100
  shadowing false
}

skinparam rectangle<<System>>{
  BackgroundColor #2b85e7
  FontColor #f1ffff
  BorderColor #1e73ce
}
skinparam rectangle<<System_extIam_ext>>{
  BackgroundColor #827a8e
  FontColor #ffffff
  BorderColor #6c6477
}
skinparam rectangle<<System_extPayment>>{
  BackgroundColor #827a8e
  FontColor #ffffff
  BorderColor #6c6477
}
skinparam rectangle<<System_extNotification>>{
  BackgroundColor #827a8e
  FontColor #ffffff
  BorderColor #6c6477
}
rectangle "Система\n\nСистема обработки пользовательских запросов" <<System>> as System
rectangle "Внешние системы" <<System_ext>> as System_ext {
  skinparam RectangleBorderColor<<System_ext>> #827a8e
  skinparam RectangleFontColor<<System_ext>> #827a8e
  skinparam RectangleBorderStyle<<System_ext>> dashed

  rectangle "IAM\n<size:10>[[OAuth2]]</size>\n\nВнешняя система аутентификации" <<System_extIam_ext>> as System_extIam_ext
  rectangle "Платежная система\n\nОбработка платежей" <<System_extPayment>> as System_extPayment
  rectangle "Уведомления\n\nОтправка уведомлений пользователям" <<System_extNotification>> as System_extNotification
}

System .[#15803d,thickness=2].> System_extIam_ext : <color:#15803d>Логин, refresh токенов, синхронизация \n<color:#15803d>пользователей\n<size:8>[<color:#15803d>HTTPS]</size>
System .[#15803d,thickness=2].> System_extPayment : <color:#15803d>Инициация платежа; приём Webhook\n<size:8>[<color:#15803d>HTTPS]</size>
System .[#15803d,thickness=2].> System_extNotification : <color:#15803d>Отправка (Email, SMS, Push)\n<size:8>[<color:#15803d>HTTPS]</size>
@enduml
